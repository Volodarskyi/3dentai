pipeline {
    agent {
        kubernetes {
            yaml """
            apiVersion: v1
            kind: Pod
            spec:
              containers:
              - name: jnlp
                image: jenkins/inbound-agent
                resources:
                  requests:
                    memory: "4Gi"
                    cpu: "4"
                  limits:
                    memory: "8Gi"
                    cpu: "8"
            """
        }
    }

    environment {
        // DockerHub token stored as a Jenkins secret
        DOCKER_HUB_TOKEN = credentials('dockerhub-token') // DockerHub token stored in Jenkins
        DOCKER_IMAGE = 'oleksiipasichnyk/confl:hackaton-server'
        K8S_MANIFEST_PATH = 'server/kubernetes-configs/server-deployment-server.yaml' // Kubernetes manifest location
        REPO_URL = 'git@github.com:Volodarskyi/3dentai.git' // Repository URL
        GIT_SSH_KEY = credentials('github-ssh-key') // GitHub SSH key for authentication
        SERVER_DIR = 'server' // Directory where the Jenkinsfile is located and the Docker build happens
    }

    triggers {
        // Poll SCM every 5 minutes
        pollSCM('H/5 * * * *')
    }

    stages {
        stage('Sparse Checkout Setup') {
            steps {
                sshagent(credentials: ['github-ssh-key']) {
                    script {
                        // Initialize a new Git repository and configure sparse checkout
                        sh """
                        git init
                        git remote add origin ${REPO_URL}
                        git config core.sparseCheckout true
                        echo '${SERVER_DIR}/*' > .git/info/sparse-checkout
                        git fetch --depth=1 origin main
                        git checkout main
                        """
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVER_DIR}") { // Move into the 'server' directory for Docker build
                    script {
                        def commitHash = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                        def date = sh(script: "date +%Y%m%d", returnStdout: true).trim()
                        def imageTag = "${DOCKER_IMAGE}-${commitHash}-${date}"

                        // Build Docker image within the 'server' directory
                        sh """
                        docker build -t ${imageTag} .
                        """
                    }
                }
            }
        }

        stage('Push Docker Image to DockerHub') {
            steps {
                dir("${SERVER_DIR}") { // Ensure we're in the correct directory
                    script {
                        def commitHash = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                        def date = sh(script: "date +%Y%m%d", returnStdout: true).trim()
                        def imageTag = "${DOCKER_IMAGE}-${commitHash}-${date}"

                        // Authenticate with DockerHub using the token and push the image
                        sh """
                        echo ${DOCKER_HUB_TOKEN} | docker login -u your-dockerhub-username --password-stdin
                        docker push ${imageTag}
                        """
                    }
                }
            }
        }

        stage('Update Kubernetes Manifest') {
            steps {
                dir("${SERVER_DIR}") { // Ensure we're in the correct directory
                    script {
                        def commitHash = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                        def date = sh(script: "date +%Y%m%d", returnStdout: true).trim()
                        def imageTag = "${DOCKER_IMAGE}-${commitHash}-${date}"

                        // Use sed to replace only the image tag part of the manifest
                        sh """
                        sed -i 's|image: oleksiipasichnyk/confl:hackaton-server-.*|image: ${imageTag}|' ${K8S_MANIFEST_PATH}
                        """
                    }
                }
            }
        }

        stage('Rebase and Push to Deploy Branch') {
            steps {
                dir("${SERVER_DIR}") { // Ensure we're in the correct directory
                    script {
                        sshagent(credentials: ['github-ssh-key']) {
                            // Rebase deploy branch on top of the main branch
                            sh """
                            git checkout deploy || git checkout -b deploy
                            git rebase origin/main
                            git add ${K8S_MANIFEST_PATH}
                            git commit -m "Update image tag to ${DOCKER_IMAGE}-${commitHash}-${date}"
                            git push --force origin deploy
                            """
                        }
                    }
                }
            }
        }
    }
}
