pipeline {
    agent {
        kubernetes {
            yaml """
            apiVersion: v1
            kind: Pod
            spec:
              containers:
              - name: kaniko
                image: gcr.io/kaniko-project/executor:latest
                args:
                - --dockerfile=/workspace/server/Dockerfile
                - --context=/workspace
                - --destination=oleksiipasichnyk/confl:hackaton-server-latest
                volumeMounts:
                - name: kaniko-secret
                  mountPath: /kaniko/.docker
              volumes:
              - name: kaniko-secret
                secret:
                  secretName: dockerhub-secret
            """
        }
    }

    environment {
        DOCKER_IMAGE = 'oleksiipasichnyk/confl:hackaton-server'
        K8S_MANIFEST_PATH = 'server/kubernetes-configs/server-deployment-server.yaml'
        REPO_URL = 'git@github.com:Volodarskyi/3dentai.git'
        GIT_SSH_KEY = credentials('github-ssh-key')
        SERVER_DIR = 'server'
    }

    stages {
        stage('Sparse Checkout Setup') {
            steps {
                sshagent(credentials: ['github-ssh-key']) {
                    script {
                        // Initialize Git repo and configure sparse checkout
                        sh """
                        git init
                        git remote add origin ${REPO_URL}
                        git config core.sparseCheckout true
                        echo '${SERVER_DIR}/*' > .git/info/sparse-checkout
                        git fetch --depth=1 origin main
                        git checkout main
                        """
                    }
                }
            }
        }

        stage('Build and Push Docker Image using Kaniko') {
            steps {
                container('kaniko') {
                    script {
                        def commitHash = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                        def date = sh(script: "date +%Y%m%d", returnStdout: true).trim()
                        def imageTag = "${DOCKER_IMAGE}-${commitHash}-${date}"

                        // Kaniko will use the context and Dockerfile to build the image and push it
                        sh """
                        /kaniko/executor --dockerfile=/workspace/server/Dockerfile \
                            --context=/workspace \
                            --destination=${imageTag} \
                            --cache=true
                        """
                    }
                }
            }
        }

        stage('Update Kubernetes Manifest') {
            steps {
                dir("${SERVER_DIR}") {
                    script {
                        def commitHash = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                        def date = sh(script: "date +%Y%m%d", returnStdout: true).trim()
                        def imageTag = "${DOCKER_IMAGE}-${commitHash}-${date}"

                        // Use sed to replace only the image tag part of the manifest
                        sh """
                        sed -i 's|image: oleksiipasichnyk/confl:hackaton-server-.*|image: ${imageTag}|' ${K8S_MANIFEST_PATH}
                        """
                    }
                }
            }
        }

        stage('Rebase and Push to Deploy Branch') {
            steps {
                dir("${SERVER_DIR}") {
                    script {
                        sshagent(credentials: ['github-ssh-key']) {
                            // Rebase deploy branch on top of the main branch
                            sh """
                            git checkout deploy || git checkout -b deploy
                            git rebase origin/main
                            git add ${K8S_MANIFEST_PATH}
                            git commit -m "Update image tag to ${DOCKER_IMAGE}-${commitHash}-${date}"
                            git push --force origin deploy
                            """
                        }
                    }
                }
            }
        }
    }
}
